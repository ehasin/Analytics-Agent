# Copy this file to .env and fill in at least one backend key.
# Do NOT commit .env — it contains real secrets.
#
# The Streamlit app also accepts keys via the sidebar at runtime;
# a .env is only needed for local CLI / notebook runs outside Colab.
#
# Colab users: add keys via Colab Secrets (🔑 icon) instead of .env.
# Secret names must match API_SECRET_NAMES in the notebook Block 1:
#   claude  → "Claude"
#   groq    → "Groq"
#   gemini  → "PersonalAPIKey"

# ── Primary backend (recommended) ───────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional alternative backends ────────────────────────────
# GROQ_API_KEY=gsk_...
# GEMINI_API_KEY=AIza...
